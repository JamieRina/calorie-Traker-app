NODE_ENV=production
APP_ENV=production
PORT=4000
APP_ORIGIN=https://app.example.com
LOCAL_BACKEND_MODE=database

# PostgreSQL and Redis
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
REDIS_URL=rediss://USER:PASSWORD@HOST:6379

# Auth
JWT_ACCESS_SECRET=replace_with_at_least_32_random_characters
JWT_REFRESH_SECRET=replace_with_a_different_32_random_characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
AUTH_REFRESH_COOKIE_NAME=bb_refresh
AUTH_COOKIE_DOMAIN=api.example.com

# Password reset
PASSWORD_RESET_BASE_URL=https://app.example.com
PASSWORD_RESET_TTL_MINUTES=30

# Signup email verification and OTP protection
OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_RESENDS=3
OTP_MAX_VERIFY_ATTEMPTS=5

# SMTP signup verification and password reset email
SMTP_PROVIDER=custom
SMTP_SES_REGION=
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_USER=replace_with_smtp_user
SMTP_PASSWORD=replace_with_smtp_password
SMTP_FROM=BiteBalance <support@example.com>

# Optional integrations
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
USDA_API_KEY=replace_with_usda_fooddata_central_key
USDA_BASE_URL=https://api.nal.usda.gov/fdc/v1
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=BiteBalance/1.0 (support@example.com)

# Workers and logging
REMINDER_QUEUE_NAME=reminders
LOG_LEVEL=info

# Optional seed script credentials. Do not use permanent production credentials here.
SEED_DEMO_EMAIL=reviewer@example.com
SEED_DEMO_PASSWORD=replace_with_a_strong_temporary_password
