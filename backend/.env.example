NODE_ENV=development
PORT=4000
APP_ORIGIN=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081
LOCAL_BACKEND_MODE=auto
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/caloriedb?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=NutriTrackPro/0.1 (your-email@example.com)
REMINDER_QUEUE_NAME=reminders
LOG_LEVEL=info
